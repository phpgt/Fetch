{
	"name": "phpgt/fetch",
	"description": "Asynchronous HTTP client with promises.",
	"type": "library",
	"license": "MIT",

	"require": {
		"php": ">=8.4",
		"ext-curl": "*",
		"ext-json": "*",
		"phpgt/async": "^1.0",
		"phpgt/promise": "^2.3",
		"phpgt/http": "^1.3",
		"phpgt/curl": "^3.2",
		"phpgt/json": "^2.2",
		"phpgt/propfunc": "^1.0"
	},

	"require-dev": {
		"phpstan/phpstan": "^1.10",
		"phpunit/phpunit": "^10.2",
		"phpmd/phpmd": "^2.13",
		"squizlabs/php_codesniffer": "^3.7"
	},

	"autoload": {
		"psr-4": {
			"GT\\Fetch\\": "./src",
			"Gt\\Fetch\\": "./src"
		},
		"files": [
			"namespace-aliases.php"
		]
	},

	"autoload-dev": {
		"psr-4": {
			"GT\\Fetch\\Test\\": "./test/phpunit"
		}
	},

	"authors": [
		{
			"name": "Greg Bowler",
			"email": "greg.bowler@g105b.com"
		}
	],

	"keywords": [
		"http-client",
		"http",
		"fetch",
		"async",
		"asynchronous",
		"xmlhttprequest",
		"ajax",
		"get",
		"post",
		"curl",
		"curl_multi"
	],

	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/PhpGt"
		}
	]
}
